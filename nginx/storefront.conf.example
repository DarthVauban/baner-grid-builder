server {
    listen 80;
    server_name used.example.com;

    location = / {
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/mt-storefront-proxy.conf;
    }

    location ^~ /smartphones/ {
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/mt-storefront-proxy.conf;
    }

    location = /storefront {
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/mt-storefront-proxy.conf;
    }

    location ^~ /storefront/smartphones/ {
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/mt-storefront-proxy.conf;
    }

    location ^~ /api/storefront/ {
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/mt-storefront-proxy.conf;
        proxy_buffering off;
        proxy_read_timeout 75s;
    }

    location ^~ /api/public/application-forms/ {
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/mt-storefront-proxy.conf;
    }

    location ^~ /media/catalog/ {
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/mt-storefront-proxy.conf;
    }

    location ^~ /web-assets/ {
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/mt-storefront-proxy.conf;
    }

    location = /mt-auto-height-sandbox.js {
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/mt-storefront-proxy.conf;
    }

    location / {
        return 404;
    }
}
